NOTION_API_KEY=secret_...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
NOTION_PARENT_PAGE_ID=<your-notion-page-id>

# LLM provider: openai (default) | anthropic
CORTEX_PROVIDER=openai

# Optional model overrides
# OpenAI (used when CORTEX_PROVIDER=openai)
CORTEX_CAPABLE_MODEL=gpt-4o
CORTEX_FAST_MODEL=gpt-4o-mini
# Anthropic (used when CORTEX_PROVIDER=anthropic)
CORTEX_OPUS_MODEL=claude-opus-4-6
CORTEX_HAIKU_MODEL=claude-haiku-4-5-20251001

# Other optional overrides
CORTEX_SCOUT_CONCURRENCY=3
CORTEX_STREAM_FLUSH_MS=1000
CORTEX_APPROVAL_POLL_MAX_S=3600
CORTEX_LLM_TIMEOUT_MS=300000
